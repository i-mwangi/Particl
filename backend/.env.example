# Qwen (Alibaba Cloud Model Studio)
# API key from the Model Studio console (DASHSCOPE_API_KEY also works as the var name)
QWEN_API_KEY = sk-your_dashscope_api_key_here
# qwen3.7-plus (default, cost-effective) or qwen3.7-max (strongest, for demos)
QWEN_MODEL = qwen3.7-plus
# Ordered fallbacks, tried in turn if the primary model errors or exhausts its
# free-tier quota (Model Studio returns 403 AllocationQuota.FreeTierOnly). Each
# model carries its own quota, so a deep chain keeps generation alive long after
# the primary runs dry. Ordered nearest-behaviour-first.
QWEN_FALLBACK_MODELS = qwen3.7-max-2026-06-08,qwen3.7-max-preview,qwen3.6-plus,qwen3.6-max-preview,qwen3.5-plus-2026-02-15,qwen3.5-122b-a10b,qwen3-max,qwen-max,qwen-plus-2025-07-28,qwen3-32b,glm-5.2,glm-5.1
# Singapore region; replace WorkspaceId with your workspace ID from the Model Studio console
QWEN_BASE_URL = https://WorkspaceId.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_MAX_OUTPUT_TOKENS = 65536
SUPABASE_URL = your_supabase_url_here
SUPABASE_ANON_KEY = your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY = your_supabase_service_role_key_here
UPSTASH_REDIS_REST_URL = your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN = your_upstash_redis_rest_token_here
UPSTASH_REDIS_HOST = oriented-dolphin-xxxx.upstash.io
UPSTASH_REDIS_PORT = 6379
UPSTASH_REDIS_PASSWORD = your_upstash_redis_password_here
JWT_SECRET = your_jwt_secret_here
